{
  "manifest_version": 3,
  "name": "PDF Dark Mode",
  "version": "1.0.0",
  "description": "Applies a customizable dark mode theme to PDFs opened in Google Chrome.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "webNavigation",
    "webRequest",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "toggle-dark-mode": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Toggle PDF Dark Mode ON/OFF"
    },
    "toggle-bionic-reading": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Toggle Bionic Reading Mode"
    },
    "toggle-reading-ruler": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Toggle Reading Ruler Guide"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "welcome.html",
        "pdfjs/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

