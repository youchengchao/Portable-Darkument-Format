{
  "manifest_version": 3,
  "name": "PDF Dark Mode - High Contrast Reader",
  "version": "2.4.0",
  "description": "Applies a customizable dark mode theme to PDFs opened in Google Chrome.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pdf-dark-mode@extension.org",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "webNavigation",
    "webRequest",
    "alarms",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "file:///*"
      ],
      "js": [
        "browser-compat.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "toggle-dark-mode": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Toggle PDF Dark Mode ON/OFF"
    },
    "toggle-bionic-reading": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Toggle Bionic Reading Mode"
    },
    "toggle-reading-ruler": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Toggle Reading Ruler Guide"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "browser-compat.js",
        "viewer.html",
        "welcome.html",
        "pdfjs/*"
      ],
      "matches": [
        "<all_urls>",
        "file:///*"
      ]
    }
  ]
}
